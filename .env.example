# Google Calendar Integration
# 1. Go to https://console.cloud.google.com/ and create a project
# 2. Enable the Google Calendar API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add http://localhost:3000/api/auth/google/callback as an authorized redirect URI
# 5. Copy Client ID and Client Secret below
# 6. Start the app and visit http://localhost:3000/api/auth/google to authorize
# 7. GOOGLE_REFRESH_TOKEN will be written to .env automatically after authorization

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=
